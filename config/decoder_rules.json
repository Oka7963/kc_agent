    }
  },
  "action_rules": {
    "scene_only": [
      {
        "scene": "compass_or_map_production",
        "target": "rashin_confirm_button",
        "reason": "dismiss_rashin_or_map_production"
      },
      {
        "scene": "formation_select",
        "target": "formation_line_ahead_button",
        "reason": "select_default_formation"
      },
      {
        "scene": "night_battle_choice",
        "target": "no_night_battle_button",
        "reason": "select_no_night_battle"
      },
      {
        "scene": "battle_result_confirm",
        "target": "result_confirm_button",
        "reason": "confirm_battle_result"
      },
      {
        "scene": "drop_confirm",
        "target": "drop_confirm_button",
        "reason": "confirm_drop"
      },
      {
        "scene": "post_battle_next",
        "target": "next_button",
        "reason": "click_post_battle_next"
      }
    ],
    "event_and_scene": [
      {
        "scene": "advance_or_retreat",
        "target": "retreat_button",
        "reason": "taiha_detected",
        "requires": {
          "taiha_latch": true
        },
        "forbid_target": "advance_button"
      }
    ]
  },
  "policy": {
    "formation": {
      "default_target": "formation_line_ahead_button",
      "submarine_node_target": "formation_line_abreast_button",
      "air_raid_node_target": "formation_diamond_button",
      "vanguard_enabled": false,
      "available_targets": [
        "formation_line_ahead_button",
        "formation_double_line_button",
        "formation_diamond_button",
        "formation_echelon_button",
        "formation_line_abreast_button",
        "formation_vanguard_button"
      ]
    },
    "night_battle": {
      "default_target": "no_night_battle_button",
      "boss_flagship_sunk_target": "no_night_battle_button",
      "boss_flagship_not_sunk_target": null,
      "notes": "When boss flagship is already sunk, skip night battle; otherwise leave unset for manual/future policy."
    },
    "route": {
      "active_branching": {
        "mode": "manual",
        "default_target": null,
        "available_targets": [
          "branch_node_a",
          "branch_node_b",
          "branch_node_c"
        ]
      }
    }
  }
}
